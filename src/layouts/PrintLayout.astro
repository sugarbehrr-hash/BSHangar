---
import { SITE, DISCLAIMER } from '../data/site';
import '../styles/global.css';
import '../styles/print.css';

/**
 * Shell for printable documents: toolbar + sheet stack.
 *
 * Deliberately NOT BaseLayout — these are documents, not pages. No site nav, no
 * footer CTA, no search. noindex because their content is a print rendering of
 * a page that is already indexed, and two URLs with identical content compete
 * with each other.
 *
 * Sheets are composed by the page via <PrintSheet>, so each document controls
 * its own pagination the way the export's .fm-page structure did.
 */
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {SITE.name}</title>
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content={description ?? title} />
    <script src="https://unpkg.com/@phosphor-icons/web@2.1.1" is:inline></script>
  </head>

  <body>
    <div class="fm-tools">
      <span class="lbl">Printable</span>
      <button class="btn btn-gold btn-sm" type="button" data-print>Print / Save as PDF</button>
      <a class="btn btn-ghost btn-sm" href="/">Back to the site</a>
    </div>

    <div class="sheet-wrap">
      <slot />
    </div>

    <p class="fm-disclaimer">{DISCLAIMER.footer}</p>

    <script>
      document.querySelector('[data-print]')?.addEventListener('click', () => window.print());
    </script>
  </body>
</html>

<style is:global>
  .fm-disclaimer {
    max-width: 816px;
    margin: 0 auto 40px;
    padding: 0 12px;
    font-size: 11px;
    line-height: 1.5;
    color: var(--ink-500);
    text-align: center;
  }
  @media print {
    .fm-disclaimer { display: none; }
  }
</style>
