---
import { SITE, UNION_REP_PHONE, DISCLAIMER } from '../data/site';
import '../styles/global.css';
import '../styles/print.css';

/**
 * Shell for the printable documents.
 *
 * Deliberately does NOT use BaseLayout: these are documents, not pages. No site
 * nav, no footer CTA, no search. They are noindex because their content is a
 * print rendering of a page that is already indexed, and two URLs competing
 * with identical content helps neither.
 */
interface Props {
  title: string;
  eyebrow: string;
  intro?: string;
  /** Running-head label on every sheet. */
  runningHead: string;
}

const { title, eyebrow, intro, runningHead } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {SITE.name}</title>
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content={intro ?? title} />
  </head>

  <body>
    <div class="fm-tools">
      <span class="lbl">Printable</span>
      <button class="btn btn-gold btn-sm" type="button" data-print>Print / Save as PDF</button>
      <a class="btn btn-ghost btn-sm" href="/">Back to the site</a>
    </div>

    <div class="sheet-wrap">
      <div class="fm-page">
        <div class="fm-mast">
          <div class="eyebrow">{eyebrow}</div>
          <h1>{title}</h1>
          {intro && <p>{intro}</p>}
        </div>

        <div class="fm-run">
          <span>{runningHead}</span>
          <span>{SITE.name}</span>
        </div>

        <div class="fm-body">
          <slot />
        </div>

        <div class="fm-foot">
          <span>© {year} {SITE.legalName}</span>
          <span>Union Rep {UNION_REP_PHONE.display}</span>
          <span>bluestreakhangar.com</span>
        </div>
      </div>
    </div>

    <p
      style="max-width:816px;margin:0 auto 40px;padding:0 12px;font-size:11px;line-height:1.5;color:var(--ink-500);text-align:center;"
    >
      {DISCLAIMER.footer}
    </p>

    <script>
      document.querySelector('[data-print]')?.addEventListener('click', () => window.print());
    </script>
  </body>
</html>
