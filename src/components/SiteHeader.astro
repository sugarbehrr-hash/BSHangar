---
import Icon from './Icon.astro';
import { BRAND, NAV, FACEBOOK_GROUP } from '../data/site';

/**
 * Sticky site header.
 *
 * The export drove nav active state with `.site[data-route=x] a[href="#x"]`
 * selectors against a hash router. With real routes the active item is known at
 * build time, so it is marked with aria-current="page" — which both styles the
 * link and tells a screen reader which page you are on. The export conveyed
 * that with colour alone.
 */
interface Props {
  /** Pathname of the current page, e.g. "/commuting/". */
  path: string;
}

const { path } = Astro.props;

/** A nav item is current if it matches exactly, or owns the section. */
function isCurrent(href: string): boolean {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
}
---

<header class="nav">
  <a href="/" class="brand" aria-label={`${BRAND.line1} home`}>
    <span class="mark"><Icon name="ph-airplane-tilt" /></span>
    <span class="wm">{BRAND.line1}<small>{BRAND.line2}</small></span>
  </a>

  <nav class="navlinks" id="navlinks" aria-label="Primary">
    {
      NAV.map((item) => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="navtools">
    <div class="search">
      <Icon name="ph-magnifying-glass" class="si" />
      <label class="sr-only" for="site-search">Search the hangar</label>
      <input
        type="search"
        id="site-search"
        name="q"
        placeholder="Search the hangar…"
        autocomplete="off"
      />
    </div>

    <a class="fbbtn" href={FACEBOOK_GROUP} target="_blank" rel="noopener">
      <Icon name="ph-facebook-logo" />
      <span>Facebook Group</span>
    </a>

    <button class="burger" type="button" aria-expanded="false" aria-controls="navlinks">
      <span class="sr-only">Menu</span>
      <Icon name="ph-list" weight="bold" />
    </button>
  </div>
</header>

<style>
  /* Visually hidden but available to assistive tech. The export had no labels
     on the search input or the burger at all. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  // Mobile menu toggle. Replaces the export's React state with the smallest
  // thing that works; the open state lives on .site so responsive.css can
  // key off it exactly as it did before.
  const burger = document.querySelector<HTMLButtonElement>('.burger');
  const site = document.querySelector<HTMLElement>('.site');

  burger?.addEventListener('click', () => {
    const open = site?.dataset.menu === '1';
    if (site) site.dataset.menu = open ? '' : '1';
    burger.setAttribute('aria-expanded', String(!open));
  });
</script>
