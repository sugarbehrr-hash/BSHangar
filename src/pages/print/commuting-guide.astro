---
import PrintLayout from '../../layouts/PrintLayout.astro';
import PrintSheet from '../../components/PrintSheet.astro';
import { richText } from '../../lib/rich-text';
import { UNION_REP_PHONE } from '../../data/site';
import {
  commuterProgram,
  commuteFailure,
  freeFlying,
  gateGuide,
  commutingCallouts,
} from '../../data/commuting';

/**
 * NOTE: this renders the same summary content as /commuting/.
 *
 * The export's CommutingGuide template is a 7-sheet, ~2,450-word field guide —
 * substantially more than the web page summarises. That full content has NOT
 * been ported into src/data yet; this document is the summary until it is.
 * Tracked so it is not forgotten.
 */
const runningHead = 'Commuting & Non-Rev';
---

<PrintLayout title="Commuting Guide" description="List early. Document everything. Arrive on time.">
  <PrintSheet runningHead={runningHead} page={1} total={2} cover>
    <div class="fm-mast">
      <div class="eyebrow">Non-Rev · List · Fly · Check In</div>
      <h1>Commuting Guide</h1>
      <p class="fm-mast-sub">List early. Document everything. Arrive on time.</p>
    </div>
    <div class="fm-cover-body">
      <div class="gd-note warn" set:html={richText(commutingCallouts.disclaimer)} />
      <p class="gd-p">
        Union Rep Assistance: <strong>{UNION_REP_PHONE.display}</strong>
      </p>
      <h2 class="gd-h2">The Commuter Program</h2>
      <p class="gd-lead">Follow these four steps every time so you stay covered under the program.</p>
      <ol class="gd-steps">
        {
          commuterProgram.map((step) => (
            <li>
              <span class="gd-step-label">{step.title}</span>
              <span class="gd-step-body" set:html={richText(step.body)} />
            </li>
          ))
        }
      </ol>
    </div>
  </PrintSheet>

  <PrintSheet runningHead={runningHead} page={2} total={2}>
    <h2 class="gd-h2">On the day</h2>
    {
      [commuteFailure, freeFlying, ...gateGuide].map((card) => (
        <div class="gd-block">
          <h3 class="gd-h3">
            {card.title}
            {card.ref && <span class="gd-ref">{card.ref}</span>}
          </h3>
          <ul class="gd-list">
            {card.points.map((point) => (
              <li set:html={richText(point)} />
            ))}
          </ul>
        </div>
      ))
    }
    <div class="gd-note" set:html={richText(commutingCallouts.idTravel)} />
  </PrintSheet>
</PrintLayout>
