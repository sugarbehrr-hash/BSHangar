---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Callout from '../components/Callout.astro';
import {
  EARNINGS,
  DEDUCTIONS,
  BRACKETS,
  DEFAULTS,
  bracketRange,
  type CheckDay,
} from '../data/paycheck';

/**
 * Crew Tools.
 *
 * The estimator's fields are server-rendered for the 5th (the default check)
 * so the page is readable and indexable without JS; the client script takes
 * over from there and re-renders the earnings list when the check changes.
 */
const shownOn = (on: CheckDay) => on === 'both' || on === 5;
const initialEarnings = EARNINGS.filter((f) => shownOn(f.on));

/** Withholding-table amounts. Whole dollars print bare, cents print in full. */
const money = (n: number) =>
  '$' +
  n.toLocaleString('en-US', {
    minimumFractionDigits: Number.isInteger(n) ? 0 : 2,
    maximumFractionDigits: 2,
  });
---

<BaseLayout
  title="Crew Tools"
  description="Crew calculators built from the group's spreadsheets. The Paycheck Estimator shows what your PSA check should be before it lands — GTD, overages, per diem, 401(k), federal withholding and dues."
>
  <div class="pagehead">
    <div class="wrap">
      <div class="ph-eyebrow">Crew calculators &amp; utilities</div>
      <h1 class="ph-title">Crew Tools</h1>
      <p class="ph-sub">
        Calculators built from the group's spreadsheets, so you can check the numbers yourself.
      </p>
    </div>
  </div>

  <section class="band cream toolband">
    <div class="wrap">
      <div class="tooltabs" role="tablist" aria-label="Tools">
        <button type="button" role="tab" id="tab-pay" data-tool="pay" aria-selected="true" aria-controls="tool-pay">
          <Icon name="ph-calculator" /> Paycheck Estimator
        </button>
        <button type="button" role="tab" id="tab-time" data-tool="time" aria-selected="false" aria-controls="tool-time">
          <Icon name="ph-clock-countdown" /> Time Out Estimator
          <span class="soonpill">Soon</span>
        </button>
      </div>

      <div id="tool-pay" role="tabpanel" aria-labelledby="tab-pay">
        <div class="estlayout">
          <div class="estmain">
      <div class="startpick reveal" role="group" aria-label="How do you want to start?">
        <p class="startpick-q">How do you want to start?</p>
        <div class="startpick-btns">
          <button type="button" data-start="upload" aria-pressed="false" aria-controls="slipcard">
            <Icon name="ph-file-pdf" />
            <span>
              Upload my payslip
              <small>Reads the PDF and fills the form for you</small>
            </span>
          </button>
          <button type="button" data-start="manual" aria-pressed="false">
            <Icon name="ph-keyboard" />
            <span>
              Enter it myself
              <small>Type the numbers from your Time Summary</small>
            </span>
          </button>
        </div>
      </div>

      <div class="slipcard reveal" id="slipcard" hidden>
        <div class="slip-head">
          <Icon name="ph-file-pdf" class="slip-icon" />
          <div>
            <h3>Start from your payslip</h3>
            <p>
              Upload the Workday <strong>Payslip to Print</strong> PDF and the fields below fill
              themselves. Your deductions are remembered on this device, so next check you only
              type the earnings that changed.
            </p>
          </div>
        </div>

        <label class="slip-drop" for="slipFile">
          <Icon name="ph-upload-simple" />
          <span><strong>Choose a payslip PDF</strong> or drop one here</span>
        </label>
        <input type="file" id="slipFile" accept="application/pdf,.pdf" class="sr-only" />

        <p class="slip-privacy">
          <Icon name="ph-lock-simple" />
          Read entirely on your own device. The file is never uploaded — this site has no server to
          send it to.
        </p>

        <div id="slipStatus" class="slip-status" role="status" hidden></div>

        <button type="button" id="slipForget" class="slip-forget" hidden>
          Forget my saved deductions
        </button>
      </div>

      <div class="esttoggle reveal" role="tablist" aria-label="Which check">
        <button type="button" role="tab" data-check="5" aria-selected="true">
          Check on the 5th<small>1 Half GTD</small>
        </button>
        <button type="button" role="tab" data-check="20" aria-selected="false">
          Check on the 20th<small>2 Half GTD + overages</small>
        </button>
      </div>

      <div class="toolcard reveal">
        <div class="tc-head">
          <h3>Earnings</h3>
          <span class="hint">from your Time Summary</span>
        </div>
        <div class="tc-body" id="earnBody">
          {
            initialEarnings.map((f) => (
              <div class="efield">
                <label>
                  {f.label}
                  {f.note && <small>{f.note}</small>}
                </label>
                <div class="emoney">
                  <input
                    type="number"
                    step="0.01"
                    min="0"
                    inputmode="decimal"
                    value={DEFAULTS[f.key]}
                    data-k={f.key}
                    aria-label={f.label}
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="toolcard reveal">
        <div class="tc-head">
          <h3>Deductions</h3>
          <span class="hint">from your paystub</span>
        </div>
        <div class="tc-body">
          <div class="egrid" id="dedBody">
            {
              DEDUCTIONS.map((f) => (
                <div class="efield">
                  <label>
                    {f.label}
                    {f.note && <small>{f.note}</small>}
                  </label>
                  <div class:list={['emoney', f.percent && 'pct']}>
                    <input
                      type="number"
                      step="0.01"
                      min="0"
                      inputmode="decimal"
                      value={DEFAULTS[f.key]}
                      data-k={f.key}
                      aria-label={f.label}
                    />
                  </div>
                </div>
              ))
            }
          </div>

          <label class="echeck">
            <input type="checkbox" id="ficaChk" checked />
            <span>
              <b>Estimate Social Security &amp; Medicare (7.65%)</b> — leave this on unless you've
              already included FICA in your Post-Tax Deductions number.
            </span>
          </label>
        </div>

        <details class="esttable-wrap">
          <summary>
            <Icon name="ph-caret-right" /> Federal withholding table (tap to view)
          </summary>
          <div class="tc-body" style="padding-top: 0;">
            <div class="esttable-scroll">
              <table class="esttable">
                <thead>
                  <tr>
                    <th>Bracket (per check)</th>
                    <th>Add (+)</th>
                    <th>Multiply (×)</th>
                    <th>Subtract (−)</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    BRACKETS.map((b) => (
                      <tr>
                        <td>{bracketRange(b)}</td>
                        <td>{money(b.add)}</td>
                        <td>{b.pct}%</td>
                        <td>{money(b.sub)}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>

            <div class="efield" style="margin-top: 10px; border-top: none;">
              <label>
                Withholding allowance<small
                  >Standard deduction per check, subtracted before finding your bracket ($358.33 =
                  Single, $537.50 = Married filing jointly)</small
                >
              </label>
              <div class="emoney">
                <input
                  type="number"
                  step="0.01"
                  min="0"
                  inputmode="decimal"
                  value={DEFAULTS.allow}
                  data-k="allow"
                  aria-label="Withholding allowance"
                />
              </div>
            </div>

            <Callout
              tone="gold"
              icon="ph-warning"
              text="**Current as of the 2026 IRS tables.** These are the official 2026 Publication 15-T percentage-method values (Single / Standard withholding, W-4 Step 2 box unchecked), converted to per-semimonthly-check amounts. They are shown for reference and are not editable. If you're Married filing jointly, set your withholding allowance to $537.50 below — note the brackets themselves are the Single table, so your federal line will read high."
              style="margin-top: 16px;"
            />
          </div>
        </details>
      </div>

            <div id="reconcile" class="toolcard reconcile" hidden>
              <div class="tc-head">
                <h3>Estimate vs. your actual payslip</h3>
                <span class="hint" id="reconcileFor"></span>
              </div>
              <div class="tc-body">
                <div id="reconcileRows"></div>
                <p class="rec-note">
                  Small differences are normal — state and local tax, mid-period benefit changes,
                  and rounding all move the number. A large gap on Federal Income Tax usually means
                  your W-4 or filing status differs from the Single table above.
                </p>
              </div>
            </div>

            <Callout
              icon="ph-info"
              text="**How it works:** taxable earnings (GTD + overages + taxable per diem + crew cash + misc) minus pre-tax deductions, 401(k), and your withholding allowance gives your federal taxable income for the check. The tool finds your bracket, figures the withholding, then subtracts everything (and adds back your non-taxable per diem). **It's an estimate, not a guarantee** — state/local taxes vary by base and aren't included; add them to Post-Tax Deductions if they apply to you. Always verify against your actual paystub."
            />
          </div>

          <aside class="estside">
            <div class="estresult" aria-live="polite">
              <div class="gl"></div>
              <div class="est-top">
                <span class="est-lbl">Expected Net Income</span>
                <span class="est-lbl alt" id="checkLbl">Check of the 5th</span>
              </div>
              <div class="est-net" id="netBig">$0.00</div>
              <div class="est-sub">
                What should hit your bank account. Compare it to your paystub — if it doesn't
                match, something changed.
              </div>
              <div class="est-break" id="breakBody"></div>
            </div>
          </aside>
        </div>
      </div>

      <div id="tool-time" role="tabpanel" aria-labelledby="tab-time" hidden>
        <div class="toolcard" style="margin-top: 0;">
          <div class="tc-body" style="padding: 44px 26px; text-align: center;">
            <Icon name="ph-clock-countdown" class="soon-icon" />
            <p class="soon-title">Coming soon</p>
            <p class="soon-body">
              This one's still on the bench. Got the duty-limit rules or a spreadsheet for it? Send
              them in the group and we'll build it faster.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { EARNINGS, BRACKETS, DEFAULTS, FICA_RATE } from '../data/paycheck';

  // Tool picker. Panels use [hidden] rather than a display style so a tool
  // that is not on screen is also out of the accessibility tree.
  const toolTabs = document.querySelector<HTMLElement>('.tooltabs');
  if (toolTabs) {
    toolTabs.addEventListener('click', (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-tool]');
      if (!button) return;

      for (const tab of toolTabs.querySelectorAll<HTMLButtonElement>('button[data-tool]')) {
        const selected = tab === button;
        tab.setAttribute('aria-selected', String(selected));
        const panel = document.getElementById(tab.getAttribute('aria-controls') ?? '');
        if (panel) panel.hidden = !selected;
      }
    });
  }

  const earnBody = document.getElementById('earnBody');
  const dedBody = document.getElementById('dedBody');
  const breakBody = document.getElementById('breakBody');
  const netBig = document.getElementById('netBig');
  const checkLbl = document.getElementById('checkLbl');
  const ficaChk = document.getElementById('ficaChk') as HTMLInputElement | null;
  const toggle = document.querySelector<HTMLElement>('.esttoggle');

  if (earnBody && dedBody && breakBody && netBig && checkLbl && ficaChk && toggle) {
    // Working copy of the user's own figures. The withholding brackets are not
    // in here on purpose: they are the published IRS values, displayed as text
    // and read straight from BRACKETS, so nothing on the page can alter them.
    const values: Record<string, number> = { ...DEFAULTS };
    let check: 5 | 20 = 5;
    let fica = true;

    const money = (n: number) =>
      (n < 0 ? '-$' : '$') +
      Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    /** Rebuild the earnings list — which fields apply depends on the check. */
    function renderEarnings() {
      const fields = EARNINGS.filter((f) => f.on === 'both' || f.on === check);
      earnBody!.innerHTML = fields
        .map(
          (f) =>
            `<div class="efield"><label>${f.label}` +
            (f.note ? `<small>${f.note}</small>` : '') +
            `</label><div class="emoney"><input type="number" step="0.01" min="0" ` +
            `inputmode="decimal" value="${values[f.key]}" data-k="${f.key}" ` +
            `aria-label="${f.label}"></div></div>`
        )
        .join('');
    }

    /**
     * The calculation on its own, with no DOM in it. Reconcile needs the same
     * figures the result card shows, and recomputing them a second way is how
     * the two drift apart.
     */
    function currentEstimate() {
      const on20 = check === 20;
      const gtd = on20 ? values.gtd2 : values.gtd1;
      const over = on20 ? values.over : 0;
      const crew = on20 ? values.crew : 0;

      const taxableEarn = gtd + over + values.pdtax + crew + values.misc;
      const k401 = (gtd + over + values.pdtax) * (values.k401 / 100);
      const fedTaxable = taxableEarn - values.pretax - k401 - values.allow;

      let fedTax = 0;
      if (fedTaxable > 0) {
        const band = BRACKETS.find((b) => fedTaxable >= b.lo && fedTaxable < b.hi);
        if (band) fedTax = Math.max(0, band.add + (fedTaxable - band.sub) * (band.pct / 100));
      }

      const ficaAmt = fica ? Math.max(0, (taxableEarn - values.pretax) * FICA_RATE) : 0;
      const net =
        taxableEarn +
        values.pdno -
        values.pretax -
        k401 -
        values.posttax -
        fedTax -
        ficaAmt -
        values.dues;

      return { taxableEarn, k401, fedTax, fica: ficaAmt, net };
    }

    function calc() {
      const { taxableEarn, k401, fedTax, fica: ficaAmt, net } = currentEstimate();

      const rows: Array<[string, number, 'pos' | 'neg']> = [
        ['Taxable earnings', taxableEarn, 'pos'],
        ['Non-taxable per diem', values.pdno, 'pos'],
        ['Pre-tax deductions', -values.pretax, 'neg'],
        ['401(k) contribution', -k401, 'neg'],
        ['Federal income tax', -fedTax, 'neg'],
      ];
      if (ficaAmt > 0) rows.push(['Social Security & Medicare', -ficaAmt, 'neg']);
      rows.push(['Post-tax deductions', -values.posttax, 'neg'], ['Union dues', -values.dues, 'neg']);

      netBig!.textContent = money(net);
      breakBody!.innerHTML =
        rows
          .filter(([label, amount]) => amount !== 0 || label === 'Taxable earnings')
          .map(
            ([label, amount, tone]) =>
              `<div class="est-brw"><span>${label}</span><span class="${tone}">${money(amount)}</span></div>`
          )
          .join('') +
        `<div class="est-brw total"><span>Expected net</span><span>${money(net)}</span></div>`;
    }

    /** One delegated handler covers the server-rendered fields and the
        re-rendered ones, so nothing has to be rebound after a toggle. */
    function onInput(event: Event) {
      const input = event.target as HTMLInputElement;
      if (!input.matches('input[data-k]')) return;

      const key = input.dataset.k;
      if (key) values[key] = parseFloat(input.value) || 0;
      calc();
    }

    document.addEventListener('input', onInput);

    // Narrowing from the guard above does not survive into these function
    // declarations, so hold the checked references directly.
    const checkToggle = toggle;

    /** Shared by the toggle and by payslip import, which also picks a check. */
    function setCheck(next: 5 | 20) {
      check = next;
      for (const b of checkToggle.querySelectorAll<HTMLButtonElement>('button[data-check]')) {
        b.setAttribute('aria-selected', String(Number(b.dataset.check) === next));
      }
      checkLbl!.textContent = next === 5 ? 'Check of the 5th' : 'Check of the 20th';
      renderEarnings();
      calc();
    }

    toggle.addEventListener('click', (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-check]');
      if (!button) return;
      setCheck(Number(button.dataset.check) === 20 ? 20 : 5);
    });

    ficaChk.addEventListener('change', () => {
      fica = ficaChk.checked;
      calc();
    });

    /* ---------- Payslip import ---------- */

    /**
     * Only the figures that hold steady between checks are remembered, and
     * only on this device. Earnings are deliberately NOT stored: they change
     * every check, and a shared crew-room computer should not hold someone's
     * pay history.
     */
    const STORE_KEY = 'bsh.paycheck.deductions.v1';
    const START_KEY = 'bsh.paycheck.start.v1';
    const STABLE_KEYS = ['pretax', 'k401', 'posttax', 'dues'] as const;

    const slipInput = document.getElementById('slipFile') as HTMLInputElement | null;
    const slipDrop = document.querySelector<HTMLElement>('.slip-drop');
    const slipStatus = document.getElementById('slipStatus');
    const slipForget = document.getElementById('slipForget') as HTMLButtonElement | null;
    const reconcile = document.getElementById('reconcile');
    const reconcileRows = document.getElementById('reconcileRows');
    const reconcileFor = document.getElementById('reconcileFor');

    function readStore(): Record<string, number> | null {
      try {
        const raw = localStorage.getItem(STORE_KEY);
        return raw ? (JSON.parse(raw) as Record<string, number>) : null;
      } catch {
        return null;
      }
    }

    function writeStore(source: Record<string, number>) {
      const keep: Record<string, number> = {};
      for (const k of STABLE_KEYS) if (typeof source[k] === 'number') keep[k] = source[k];
      try {
        localStorage.setItem(STORE_KEY, JSON.stringify(keep));
        if (slipForget) slipForget.hidden = false;
      } catch {
        /* storage disabled — prefill simply will not persist */
      }
    }

    /** Write values into state and sync any matching input already on screen. */
    function applyValues(incoming: Record<string, number>) {
      for (const [key, value] of Object.entries(incoming)) {
        if (!Number.isFinite(value)) continue;
        values[key] = value;
        const field = document.querySelector<HTMLInputElement>(`input[data-k="${key}"]`);
        if (field) field.value = String(value);
      }
    }

    function setStatus(html: string, tone: 'ok' | 'bad' | '') {
      if (!slipStatus) return;
      slipStatus.className = `slip-status${tone ? ' ' + tone : ''}`;
      slipStatus.innerHTML = html;
      slipStatus.hidden = false;
    }

    const asMoney = (n: number) =>
      (n < 0 ? '-$' : '$') +
      Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    /** Estimate vs. actual, once a payslip has supplied real figures. */
    function showReconcile(actual: { federal: number | null; fica: number | null; net: number | null }, label: string) {
      if (!reconcile || !reconcileRows) return;
      const estimate = currentEstimate();
      const rows: Array<[string, number, number]> = [];
      if (actual.federal !== null) rows.push(['Federal income tax', estimate.fedTax, actual.federal]);
      if (actual.fica !== null) rows.push(['Social Security & Medicare', estimate.fica, actual.fica]);
      if (actual.net !== null) rows.push(['Net pay', estimate.net, actual.net]);

      if (rows.length === 0) {
        reconcile.hidden = true;
        return;
      }

      if (reconcileFor) reconcileFor.textContent = label;
      reconcileRows.innerHTML =
        '<div class="rec-head"><span>Line</span><span class="rec-figs"><span>Estimated</span><span>Actual</span><span>Difference</span></span></div>' +
        rows
          .map(([name, est, act]) => {
            const diff = act - est;
            // Within a dollar is rounding, not a discrepancy worth alarming over.
            const tone = Math.abs(diff) <= 1 ? 'close' : 'off';
            return (
              `<div class="rec-row"><span class="rec-label">${name}</span>` +
              `<span class="rec-figs">` +
              `<span class="rec-est">${asMoney(est)}</span>` +
              `<span class="rec-act">${asMoney(act)}</span>` +
              `<span class="rec-diff ${tone}">${diff >= 0 ? '+' : ''}${asMoney(diff)}</span>` +
              `</span></div>`
            );
          })
          .join('');
      reconcile.hidden = false;
    }

    async function handleFile(file: File) {
      if (!file.name.toLowerCase().endsWith('.pdf') && file.type !== 'application/pdf') {
        setStatus("That doesn't look like a PDF. Use the <strong>Payslip to Print</strong> download from Workday.", 'bad');
        return;
      }

      setStatus('Reading your payslip…', '');

      try {
        const [{ parsePayslip }, { mapPayslip }] = await Promise.all([
          import('../lib/payslip'),
          import('../lib/payslip-map'),
        ]);

        const slip = await parsePayslip(file);
        const mapped = mapPayslip(slip);

        if (Object.keys(mapped.values).length === 0) {
          setStatus(
            "Couldn't find any pay lines in that PDF. If it opens correctly in a PDF reader, it may be a different report — this expects Workday's <strong>Payslip to Print</strong>.",
            'bad'
          );
          return;
        }

        applyValues(mapped.values);
        if (mapped.check) setCheck(mapped.check);
        else calc();

        writeStore(mapped.values);

        const filled = Object.keys(mapped.values).length;
        const when = slip.checkDate ? ` dated ${slip.checkDate}` : '';
        let html = `<strong>Filled ${filled} field${filled === 1 ? '' : 's'}</strong> from your payslip${when}. Check them against the PDF before trusting the result.`;

        const warnings = [...mapped.notes, ...mapped.unmapped.map((u) => `Not used: ${u}`)];
        if (warnings.length) {
          html += '<ul>' + warnings.map((w) => `<li class="warn">${w}</li>`).join('') + '</ul>';
        }
        setStatus(html, 'ok');

        showReconcile(mapped.actual, slip.checkDate ? `check dated ${slip.checkDate}` : '');
      } catch (error) {
        setStatus(
          `Could not read that PDF. ${error instanceof Error ? error.message : 'Unknown error'}`,
          'bad'
        );
      }
    }

    slipInput?.addEventListener('change', () => {
      const file = slipInput.files?.[0];
      if (file) void handleFile(file);
    });

    if (slipDrop) {
      for (const type of ['dragenter', 'dragover'] as const) {
        slipDrop.addEventListener(type, (e) => {
          e.preventDefault();
          slipDrop.classList.add('dragging');
        });
      }
      for (const type of ['dragleave', 'drop'] as const) {
        slipDrop.addEventListener(type, () => slipDrop.classList.remove('dragging'));
      }
      slipDrop.addEventListener('drop', (event) => {
        event.preventDefault();
        const file = (event as DragEvent).dataTransfer?.files?.[0];
        if (file) void handleFile(file);
      });
    }

    slipForget?.addEventListener('click', () => {
      try {
        localStorage.removeItem(STORE_KEY);
      } catch {
        /* nothing to clear */
      }
      slipForget.hidden = true;
      setStatus('Saved deductions cleared from this device.', '');
    });

    /* ---------- How to start ---------- */

    const startPick = document.querySelector<HTMLElement>('.startpick');
    const slipCard = document.getElementById('slipcard');

    /**
     * Typing the numbers in is a first-class path. The upload panel stays
     * collapsed until it is chosen, so the PDF never reads as a requirement
     * for crew who do not have one to hand.
     */
    function chooseStart(mode: 'upload' | 'manual', remember = true) {
      if (!startPick) return;

      for (const b of startPick.querySelectorAll<HTMLButtonElement>('button[data-start]')) {
        b.setAttribute('aria-pressed', String(b.dataset.start === mode));
      }
      if (slipCard) slipCard.hidden = mode !== 'upload';

      if (remember) {
        try {
          localStorage.setItem(START_KEY, mode);
        } catch {
          /* choice simply will not persist */
        }
      }
    }

    startPick?.addEventListener('click', (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-start]');
      if (!button) return;

      const mode = button.dataset.start === 'upload' ? 'upload' : 'manual';
      chooseStart(mode);

      if (mode === 'manual') {
        // Drop them straight onto the first thing they need to type.
        earnBody.querySelector<HTMLInputElement>('input[data-k]')?.focus();
      } else {
        slipInput?.focus();
      }
    });

    // Restore remembered deductions on load.
    const saved = readStore();
    if (saved && Object.keys(saved).length) {
      applyValues(saved);
      if (slipForget) slipForget.hidden = false;
    }

    // Restore the previous choice, without re-saving it.
    try {
      const previous = localStorage.getItem(START_KEY);
      if (previous === 'upload' || previous === 'manual') chooseStart(previous, false);
    } catch {
      /* no stored preference */
    }

    calc();
  }
</script>
